# ============================================================================
#  AI Moot Court — environment variables
#  Copy this file to .env and fill in your keys.
# ============================================================================

# ---- LLM backend (groq is free — recommended) ----
MOOT_COURT_LLM=groq
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Anthropic Claude (optional) ----
# MOOT_COURT_LLM=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# MOOT_COURT_MODEL=claude-sonnet-4-6

# ---- Google Gemini (optional, free tier) ----
# MOOT_COURT_LLM=gemini
# GOOGLE_API_KEY=AIza-xxxxx
# GEMINI_MODEL=gemini-2.0-flash

# ---- Embeddings (Hugging Face Hub — avoids unauthenticated rate limits) ----
HF_TOKEN=your-hf-token-here

# ---- Precedent search (Tavily) ----
TAVILY_API_KEY=your-tavily-key-here

# ---- LangSmith tracing ----
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=ai-moot-court

# ---- Graph behaviour ----
MOOT_COURT_MAX_ROUNDS=3
